# ===== KIS LLM Trader 환경변수 (실값은 .env 에만 — .env 는 절대 커밋 금지) =====

# --- 실행 환경 선택: vps(모의투자) | prod(실전). 반드시 vps 로 충분히 검증 후 prod 전환 ---
KIS_ENV=vps

# --- KIS Open API 크리덴셜 (모의/실전 각각 별도 발급) ---
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PROD_APP_KEY=
KIS_PROD_APP_SECRET=

# HTS ID (실시간 웹소켓 승인용)
KIS_HTS_ID=
# 계좌번호: 앞 8자리 + 상품코드 2자리(주식=01)
KIS_ACCOUNT_8=
KIS_ACCOUNT_PD=01

# --- Anthropic (LLM 의사결정) ---
ANTHROPIC_API_KEY=
# 기본 저비용 모델. 깊은 분석이 필요하면 claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5

# --- 디스코드 알림 Webhook ---
# 일반 채널: 중요 이벤트만(체결/손절/가드레일 차단/일일요약/에러/기동·종료)
DISCORD_WEBHOOK_URL=
# trade-log 채널: 매 사이클 LLM 결정 전부(HOLD/축소/차단 포함). 비우면 일반 채널로 폴백.
# ⚠️ 결정이 자주 쏟아지므로 반드시 별도 채널 권장(레이트리밋·노이즈 분리).
DISCORD_TRADELOG_URL=

# --- 디스코드 양방향 조회 봇(선택) ---
# 채널에서 잔고/보유/체결/매수가능을 질의→응답. 끄면(false) 토큰 불필요.
DISCORD_BOT_ENABLED=false
# 봇 토큰 — Developer Portal 발급. ⚠️ Message Content Intent 활성화 필수. 절대 커밋 금지.
DISCORD_BOT_TOKEN=
# 조회 허용 채널 ID(0이면 전체 허용). ⚠️ 계좌 정보 노출되므로 운영 시 특정 채널 ID 권장.
DISCORD_BOT_CHANNEL_ID=0

# ===== 가드레일(코드 강제 안전장치) 파라미터 =====
# 1회 매수 최대 금액(원)
MAX_ORDER_KRW=100000
# 종목당 최대 비중(0~1). 총평가금액 대비
MAX_POSITION_PCT=0.4
# 일일 최대 손실(원) — 도달 시 당일 매매 중단(kill switch)
DAILY_MAX_LOSS_KRW=30000
# 하루 최대 거래 횟수
MAX_TRADES_PER_DAY=5
# 하드 손절선(%) — 도달 시 LLM 의견 무시하고 즉시 청산. 음수로 입력
HARD_STOP_LOSS_PCT=-10.0

# --- 운용 대상/주기 ---
# 관심종목 코드 콤마구분 (예: 005930=삼성전자)
WATCH_CODES=005930
# 활성 전략 프리셋 (strategy/presets.py). 미지정 시 golden_cross.
# 사용 가능: golden_cross, momentum, week52_high, consecutive, disparity,
#           breakout_fail, strong_close, volatility, mean_reversion, trend_filter
STRATEGY_NAME=golden_cross
# LLM 의사결정 호출 간격(분)
DECISION_INTERVAL_MIN=15
# SQLite 저널 경로
JOURNAL_DB=trader.db

# --- 로깅 ---
# 파일 로그 레벨(DEBUG 권장 — 상세 추적용). 콘솔은 항상 INFO.
LOG_LEVEL=DEBUG
# 상세 로그 파일 경로(5MB×5 로테이션). 비우면 파일 로그 비활성(콘솔만).
LOG_FILE=logs/trader.log
